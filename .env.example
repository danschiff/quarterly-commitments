# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real tokens.

# Required: Jira API token for the account configured in config.yaml.
# Generate one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Optional (future): Slack bot token for posting messages directly to Slack.
# Required scopes: conversations:write, im:write, mpim:write
# SLACK_BOT_TOKEN=
